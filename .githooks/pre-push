#!/usr/bin/env bash
# pre-push (AGENTS §7): bloquea push directo y force-push (non-fast-forward) a la rama principal.
# No saltear con --no-verify; prohibido --force sobre main.
set -euo pipefail

protected="refs/heads/main refs/heads/master"
z="0000000000000000000000000000000000000000"

while read -r _local_ref local_sha remote_ref remote_sha; do
  for p in $protected; do
    if [ "$remote_ref" = "$p" ]; then
      echo "✗ pre-push: push directo a '${remote_ref#refs/heads/}' bloqueado. Mergeá por PR (AGENTS §1)." >&2
      exit 1
    fi
  done
  # Force-push (non-fast-forward) a cualquier rama: el remoto existe y no es ancestro del local.
  if [ "$remote_sha" != "$z" ] && [ "$local_sha" != "$z" ]; then
    if ! git merge-base --is-ancestor "$remote_sha" "$local_sha" 2>/dev/null; then
      echo "✗ pre-push: force-push / non-fast-forward bloqueado sobre '${remote_ref#refs/heads/}'." >&2
      exit 1
    fi
  fi
done
exit 0
