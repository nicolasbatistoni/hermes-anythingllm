#!/usr/bin/env bash
# pre-commit (AGENTS §7): bloquea commit directo a la rama principal, archivos enormes y
# secrets obvios. No saltear con --no-verify.
set -euo pipefail

branch="$(git symbolic-ref --short HEAD 2>/dev/null || echo '')"
if [ "$branch" = "main" ] || [ "$branch" = "master" ]; then
  echo "✗ pre-commit: no se commitea directo a '$branch'. Usá una branch corta + PR (AGENTS §1)." >&2
  exit 1
fi

# Archivos enormes (>50 MB) recién agregados/modificados (los renames de assets ya versionados
# no cuentan). El umbral es alto para no molestar en repos con assets/lockfiles legítimos; blobs enormes van a Git LFS.
max=$((50 * 1024 * 1024))
while IFS=$'\t' read -r status path; do
  case "$status" in A*|M*) ;; *) continue ;; esac
  [ -f "$path" ] || continue
  size=$(wc -c < "$path")
  if [ "$size" -gt "$max" ]; then
    echo "✗ pre-commit: '$path' pesa $((size/1024/1024)) MB (>50 MB). ¿Va con Git LFS o fuera del repo?" >&2
    exit 1
  fi
done < <(git diff --cached --name-status --diff-filter=AM)

# Secrets obvios en el contenido staged.
if git diff --cached -U0 --diff-filter=AM | grep -nEi \
   '(AKIA[0-9A-Z]{16}|-----BEGIN [A-Z ]*PRIVATE KEY-----|ghp_[0-9A-Za-z]{36}|xox[baprs]-[0-9A-Za-z-]+)' >/dev/null; then
  echo "✗ pre-commit: posible secret en el diff staged. Revisá antes de commitear." >&2
  exit 1
fi
exit 0
