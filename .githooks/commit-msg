#!/usr/bin/env bash
# commit-msg (AGENTS §7): exige Conventional Commits con los types permitidos.
# Tipos: feat fix docs style refactor perf test build ci chore revert  (+ scope opcional, + ! breaking)
set -euo pipefail

msg_file="$1"
header="$(head -n1 "$msg_file")"

# Permitir merges y mensajes de fixup/squash.
case "$header" in
  "Merge "*|"Revert "*|"fixup! "*|"squash! "*) exit 0 ;;
esac

re='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9._/-]+\))?!?: .+'
if ! printf '%s' "$header" | grep -qE "$re"; then
  echo "✗ commit-msg: el título no cumple Conventional Commits." >&2
  echo "  Formato: <type>(<scope>)?: <descripción>   p. ej.  feat(gangsters): agrega minimapa" >&2
  echo "  Types: feat fix docs style refactor perf test build ci chore revert" >&2
  exit 1
fi
exit 0
